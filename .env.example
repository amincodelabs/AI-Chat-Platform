# Local Docker settings. Copy to .env if you want to override defaults.
PRIVATEAICHAT_SQL_PASSWORD=Local_dev_only_ChangeMe_123
PRIVATEAICHAT_SQL_PORT=14333
PRIVATEAICHAT_WEB_PORT=5080
PRIVATEAICHAT_API_PORT=5081
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_SECONDS=120
RATE_LIMIT_AUTH_PERMIT_LIMIT=5
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_CHAT_PERMIT_LIMIT=20
RATE_LIMIT_CHAT_WINDOW_SECONDS=60
RATE_LIMIT_GENERAL_PERMIT_LIMIT=120
RATE_LIMIT_GENERAL_WINDOW_SECONDS=60

# Production Docker settings for docker-compose.prod.yml.
# Use a strong SQL password and set the edition to a licensed or permitted value for your deployment.
PRIVATEAICHAT_HTTP_PORT=80
PRIVATEAICHAT_SQL_PASSWORD=ChangeMeToAStrongProductionPassword123!
PRIVATEAICHAT_SQL_PID=Express
PRIVATEAICHAT_APPLY_MIGRATIONS=false
PRIVATEAICHAT_AUTH_COOKIE_SECURE_POLICY=SameAsRequest
