@page "/login"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using PrivateAiChat.Contracts.Auth
@inject AuthApiClient AuthApiClient
@inject ApiCookieStore ApiCookieStore
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<div class="auth-page">
    <AuthCard Eyebrow="Private workspace" Title="Welcome back" Subtitle="Sign in to continue your private workspace.">
        <EditForm Model="model" OnValidSubmit="SubmitAsync" class="auth-form">
            <DataAnnotationsValidator />

            <div class="field">
                <label for="email">Email</label>
                <InputText id="email" class="text-input" @bind-Value="model.Email" autocomplete="email" />
                <ValidationMessage For="() => model.Email" />
            </div>

            <div class="field">
                <label for="password">Password</label>
                <InputText id="password" type="password" class="text-input" @bind-Value="model.Password" autocomplete="current-password" />
                <ValidationMessage For="() => model.Password" />
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="form-alert">@errorMessage</div>
            }

            <button class="primary-button" type="submit" disabled="@isLoading">
                @(isLoading ? "Signing in..." : "Sign in")
            </button>

            <p class="form-switch">New here? <a href="signup">Create an account</a></p>
        </EditForm>
    </AuthCard>
</div>

@code {
    private readonly LoginFormModel model = new();
    private bool isLoading;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        if (AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/chat", replace: true);
        }
    }

    private async Task SubmitAsync()
    {
        isLoading = true;
        errorMessage = null;

        var result = await AuthApiClient.LoginAsync(
            new LoginRequest(model.Email, model.Password),
            CancellationToken.None);

        if (result.Succeeded && result.Value is not null)
        {
            await AuthState.SetUserAsync(result.Value);
            await ApiCookieStore.PersistAsync();
            Navigation.NavigateTo("/chat", replace: true);
            return;
        }

        errorMessage = result.Error ?? "Sign in failed.";
        isLoading = false;
    }

    private sealed class LoginFormModel
    {
        [Required]
        [EmailAddress]
        [MaxLength(256)]
        public string Email { get; set; } = string.Empty;

        [Required]
        [MaxLength(128)]
        public string Password { get; set; } = string.Empty;
    }
}
