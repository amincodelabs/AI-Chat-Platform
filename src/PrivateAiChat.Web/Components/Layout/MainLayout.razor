@inherits LayoutComponentBase
@inject AppBootstrapService AppBootstrap

<div class="app-shell">
    <header class="app-header">
        <a class="brand" href="">
            <span class="brand-mark">P</span>
            <span>PrivateAiChat</span>
        </a>

        <div class="shell-actions">
            <ThemeToggle />
            <LogoutButton />
        </div>
    </header>

    <main class="app-main">
        @if (!AppBootstrap.IsInitialized)
        {
            <section class="app-loading">
                <p class="eyebrow">Loading</p>
                <h1>Preparing your workspace</h1>
                <div class="typing-indicator typing-indicator--center" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            </section>
        }
        else
        {
            @Body
        }
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await AppBootstrap.InitializeAsync();
        StateHasChanged();
    }
}
