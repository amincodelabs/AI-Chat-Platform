@inherits LayoutComponentBase

<div class="app-shell">
    <header class="app-header">
        <a class="brand" href="">
            <span class="brand-mark">P</span>
            <span>PrivateAiChat</span>
        </a>

        <nav class="shell-nav" aria-label="Primary">
            <NavLink class="shell-link" href="" Match="NavLinkMatch.All">Home</NavLink>
            <NavLink class="shell-link" href="chat">Chat</NavLink>
            <NavLink class="shell-link" href="login">Login</NavLink>
            <NavLink class="shell-link" href="signup">Signup</NavLink>
            <LogoutButton />
            <ThemeToggle />
        </nav>
    </header>

    <main class="app-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>
