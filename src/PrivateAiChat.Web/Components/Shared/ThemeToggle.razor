@rendermode InteractiveServer
@implements IDisposable
@inject ThemeService ThemeService

<button class="icon-button icon-button--ghost" type="button" title="Toggle theme" aria-label="Toggle theme" @onclick="ToggleThemeAsync">
    <span>@Label</span>
</button>

@code {
    private string Label => ThemeService.CurrentTheme switch
    {
        "dark" => "Light",
        "light" => "System",
        _ => "Dark"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await ThemeService.InitializeAsync();
        StateHasChanged();
    }

    private async Task ToggleThemeAsync()
    {
        await ThemeService.ToggleAsync();
        StateHasChanged();
    }

    public void Dispose()
    {
    }
}
