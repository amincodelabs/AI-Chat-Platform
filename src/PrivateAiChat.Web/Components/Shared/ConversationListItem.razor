@using PrivateAiChat.Contracts.Conversations
@inject IJSRuntime JsRuntime

<button class="conversation-item @(IsSelected ? "conversation-item--active" : null)"
        type="button"
        title="@DisplayTitle"
        @onclick="OnSelected">
    <span class="conversation-item__title">@DisplayTitle</span>
    <span class="conversation-item__preview">@UpdatedDescription</span>
    <time datetime="@Conversation.UpdatedAt.ToString("O")" title="@UpdatedTitle">@UpdatedLabel</time>
</button>

@code {
    [Parameter, EditorRequired]
    public ConversationSummaryResponse Conversation { get; set; } = default!;

    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter, EditorRequired]
    public EventCallback OnSelected { get; set; }

    private DateTimeOffset formattedUpdatedAt;
    private string? localUpdatedLabel;
    private string? localUpdatedTitle;

    private string DisplayTitle => string.IsNullOrWhiteSpace(Conversation.Title)
        ? "Untitled conversation"
        : Conversation.Title;

    private string UpdatedLabel => string.IsNullOrWhiteSpace(localUpdatedLabel)
        ? Conversation.UpdatedAt.UtcDateTime.ToString("MMM d")
        : localUpdatedLabel;

    private string UpdatedDescription => $"Updated {UpdatedLabel}";

    private string UpdatedTitle => string.IsNullOrWhiteSpace(localUpdatedTitle)
        ? Conversation.UpdatedAt.UtcDateTime.ToString("O")
        : localUpdatedTitle;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (formattedUpdatedAt == Conversation.UpdatedAt)
        {
            return;
        }

        try
        {
            var result = await JsRuntime.InvokeAsync<BrowserTimeFormatResult>(
                "privateAiChatTime.format",
                Conversation.UpdatedAt.ToString("O"),
                "conversation");

            formattedUpdatedAt = Conversation.UpdatedAt;
            localUpdatedLabel = result.Label;
            localUpdatedTitle = result.Title;
            StateHasChanged();
        }
        catch
        {
            formattedUpdatedAt = Conversation.UpdatedAt;
        }
    }

    private sealed class BrowserTimeFormatResult
    {
        public string? Label { get; set; }

        public string? Title { get; set; }
    }
}
